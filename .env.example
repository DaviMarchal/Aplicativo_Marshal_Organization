# Copie este arquivo para ".env" antes de rodar o projeto.
# Esses valores já batem com o docker-compose.yml — não precisa mudar nada
# se você for usar o MySQL via Docker Compose.

# ---- Servidor ----
PORT=4000
NODE_ENV=development

# ---- Multi-usuário (deploy web) ----
# Deixe "false" (ou remova a linha) para o app desktop: sem login, sempre
# usuário id=1, igual sempre foi. Só ligue "true" no deploy web (Netlify +
# host do backend), onde cada pessoa cria a própria conta.
MULTI_USER=false
# Segredo usado para assinar o cookie de sessão — gere um valor aleatório
# longo pra produção (ex: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`).
SESSION_SECRET=troque_isso_em_producao
# Origens permitidas a chamar a API com cookies (separadas por vírgula).
# Só é usado quando MULTI_USER=true — ex: https://seuapp.netlify.app
CORS_ORIGIN=

# ---- MySQL ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=momentum_dev_pw
DB_NAME=momentum

# Usado apenas pelo docker-compose.yml para inicializar o container do MySQL
MYSQL_ROOT_PASSWORD=momentum_dev_pw
MYSQL_DATABASE=momentum
